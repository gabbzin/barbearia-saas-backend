generator client {
  provider     = "prisma-client-js"
  engineType   = "library"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String       @id @default(uuid())
  name             String
  image            String?
  email            String       @unique
  emailVerified    Boolean      @default(false)
  password         String?
  stripeCustomerId String?
  tenantId         String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @default(now()) @updatedAt
  barberProfile    Barber[]
  tenants          UserTenant[]
  accounts         Account[]
  sessions         Session[]

  @@map("user")
}

model UserTenant {
  userId       String
  tenantId     String
  role         userRole      @default(CLIENT)
  bookings     Booking[]
  tenant       Barbershop    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription?

  @@id([userId, tenantId])
  @@index([tenantId])
}

model Barbershop {
  id            String                @id @default(uuid())
  name          String
  slug          String                @unique
  address       String
  logo          String                @default("https://3tlh7aktl6.ufs.sh/f/tcFRjMXVSkQ0Asb1IxZDwZ30bIph8P2qjXfOcVJmTvFtnMxi")
  timezone      String                @default("America/Sao_Paulo")
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  barbers       Barber[]
  disponibility BarberDisponibility[]
  services      BarberService[]
  plan          Plan[]
  users         UserTenant[]

  @@map("barbershops")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  tenantId  String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Barber {
  id             String                @id @default(uuid())
  phone          String
  userId         String
  tenantId       String
  tenant         Barbershop            @relation(fields: [tenantId], references: [id])
  user           User                  @relation(fields: [userId], references: [id])
  disponibility  BarberDisponibility[]
  services       BarberService[]
  bookings       Booking[]
  exceptionDates ExceptionDate[]

  @@unique([userId, tenantId])
  @@index([userId])
}

model BarberService {
  id                String     @id @default(uuid())
  name              String
  description       String
  imageUrl          String
  priceInCents      Int
  durationInMinutes Int        @default(30)
  barberId          String
  tenantId          String
  barber            Barber     @relation(fields: [barberId], references: [id])
  tenant            Barbershop @relation(fields: [tenantId], references: [id])
  bookings          Booking[]

  @@index([barberId, tenantId])
}

model Booking {
  id                   String        @id @default(uuid())
  date                 DateTime      @db.Timestamptz(6)
  status               BookingStatus @default(SCHEDULED)
  priceInCents         Int
  serviceId            String
  userId               String
  tenantId             String
  barberId             String
  userSubscriptionId   String?
  paidWithSubscription Boolean       @default(false)
  stripeChargeId       String?       @unique
  stripeEventId        String?       @unique
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  cancelledAt          DateTime?     @db.Timestamptz(6)
  barber               Barber        @relation(fields: [barberId], references: [id])
  service              BarberService @relation(fields: [serviceId], references: [id])
  userTenant           UserTenant    @relation(fields: [userId, tenantId], references: [userId, tenantId], onDelete: Cascade)

  @@index([userId, tenantId])
  @@index([barberId, date])
  @@index([tenantId, date])
}

model Subscription {
  id                   String              @id @default(uuid())
  planId               String?
  stripeCustomerId     String?
  stripeSubscriptionId String?             @unique
  status               SubscriptionStatus? @default(INCOMPLETE)
  periodStart          DateTime?
  periodEnd            DateTime?
  trialStart           DateTime?
  trialEnd             DateTime?
  cancelAtPeriodEnd    Boolean?            @default(false)
  seats                Int?
  userId               String
  tenantId             String
  plan                 Plan?               @relation(fields: [planId], references: [id])
  userTenant           UserTenant          @relation(fields: [userId, tenantId], references: [userId, tenantId], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([userId, planId])
  @@map("subscription")
}

model Plan {
  id            String         @id @default(uuid())
  name          String
  description   String
  priceInCents  Int
  stripePriceId String?
  tenantId      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tenant        Barbershop?    @relation(fields: [tenantId], references: [id])
  subscriptions Subscription[]

  @@index([tenantId])
}

model BarberDisponibility {
  id        String     @id @default(uuid())
  dayOfWeek Int
  startTime DateTime   @db.Time(6)
  endTime   DateTime   @db.Time(6)
  barberId  String
  tenantId  String
  barber    Barber     @relation(fields: [barberId], references: [id], onDelete: Cascade)
  tenant    Barbershop @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([barberId, dayOfWeek])
  @@index([barberId, dayOfWeek])
}

model ExceptionDate {
  id        String    @id @default(uuid())
  date      DateTime  @db.Date
  isClosed  Boolean   @default(true)
  startTime DateTime? @db.Time(6)
  endTime   DateTime? @db.Time(6)
  barberId  String
  barber    Barber    @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([barberId, date])
  @@index([barberId, date])
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  INCOMPLETE
}

enum userRole {
  CLIENT
  BARBER
  ADMIN
}

enum BookingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}
