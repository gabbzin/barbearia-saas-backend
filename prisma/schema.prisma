generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String       @id @default(uuid())
  name             String
  email            String       @unique
  emailVerified    Boolean      @default(false)
  role             userRole     @default(CLIENT)
  password         String?
  passwordHash     String?
  image            String?
  tenantId         String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @default(now()) @updatedAt
  stripeCustomerId String?
  barberProfile    Barber?      @relation("BarberAccount")
  tenants          UserTenant[]
  ratings          Rating[]
  accounts         Account[]
  sessions         Session[]

  @@map("user")
}

model UserTenant {
  userId       String
  tenantId     String
  role         userRole      @default(CLIENT)
  bookings     Booking[]
  subscription Subscription?
  tenant       Barbershop    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, tenantId])
  @@index([tenantId])
  @@index([userId])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Barbershop {
  id            String                @id @default(uuid())
  name          String
  slug          String                @unique
  address       String
  logo          String                @default("https://3tlh7aktl6.ufs.sh/f/tcFRjMXVSkQ0Asb1IxZDwZ30bIph8P2qjXfOcVJmTvFtnMxi")
  imageUrl      String?               @default("https://3tlh7aktl6.ufs.sh/f/tcFRjMXVSkQ0Asb1IxZDwZ30bIph8P2qjXfOcVJmTvFtnMxi")
  timezone      String                @default("America/Sao_Paulo")
  storageUrl    String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  barbers       Barber[]
  disponibility BarberDisponibility[]
  services      BarberService[]
  plans         Plan[]
  users         UserTenant[]
  bookings      Booking[]
  ratings       Rating[]
  socialMedia   SocialMedia[]
  breaks        BarberBreak[]
  exceptions    ExceptionDate[]

  @@map("barbershops")
}

model Barber {
  id             String                @id @default(uuid())
  phone          String
  userId         String?               @unique
  tenantId       String
  tenant         Barbershop            @relation(fields: [tenantId], references: [id])
  user           User?                 @relation("BarberAccount", fields: [userId], references: [id])
  barberBreaks   BarberBreak[]
  services       BarberService[]
  bookings       Booking[]
  disponibility  BarberDisponibility[]
  exceptionDates ExceptionDate[]
  ratings        Rating[]
  socialMedia    SocialMedia[]

  @@index([userId])
}

model BarberService {
  id                String     @id @default(uuid())
  name              String
  description       String
  imageUrl          String
  priceInCents      Int
  barberId          String
  tenantId          String
  durationInMinutes Int        @default(30)
  barber            Barber     @relation(fields: [barberId], references: [id])
  tenant            Barbershop @relation(fields: [tenantId], references: [id])
  bookings          Booking[]

  @@index([barberId, tenantId])
}

model BarberBreak {
  id        String     @id @default(uuid())
  barberId  String
  tenantId  String
  dayOfWeek Int
  startTime String
  endTime   String
  barber    Barber     @relation(fields: [barberId], references: [id], onDelete: Cascade)
  tenant    Barbershop @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([barberId, dayOfWeek, startTime, endTime, tenantId])
}

model Subscription {
  id                   String              @id @default(uuid())
  planId               String?
  stripeCustomerId     String?
  stripeSubscriptionId String?             @unique
  status               SubscriptionStatus? @default(INCOMPLETE)
  periodStart          DateTime?
  periodEnd            DateTime?
  trialStart           DateTime?
  trialEnd             DateTime?
  cancelAtPeriodEnd    Boolean?            @default(false)
  seats                Int?
  userId               String
  tenantId             String
  plan                 Plan?               @relation(fields: [planId], references: [id])
  userTenant           UserTenant          @relation(fields: [userId, tenantId], references: [userId, tenantId], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([userId, planId])
  @@map("subscription")
}

model Plan {
  id            String         @id @default(uuid())
  name          String
  description   String
  priceInCents  Int
  stripePriceId String?
  tenantId      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  benefits      String[]       @default([])
  imageUrl      String?
  tenant        Barbershop?    @relation(fields: [tenantId], references: [id])
  subscriptions Subscription[]

  @@index([tenantId])
}

model Booking {
  id                   String        @id @default(uuid())
  date                 DateTime      @db.Timestamptz(6)
  serviceId            String
  userId               String
  tenantId             String
  barberId             String
  userSubscriptionId   String?
  paidWithSubscription Boolean       @default(false)
  stripeChargeId       String?       @unique
  stripeEventId        String?       @unique
  cancelledAt          DateTime?     @db.Timestamptz(6)
  createdAt            DateTime      @default(now())
  status               BookingStatus @default(SCHEDULED)
  updatedAt            DateTime      @updatedAt
  priceInCents         Int
  customerName         String?
  customerPhone        String?
  paymentMethod        String?
  barber               Barber        @relation(fields: [barberId], references: [id])
  tenant               Barbershop    @relation(fields: [tenantId], references: [id])
  service              BarberService @relation(fields: [serviceId], references: [id])
  userTenant           UserTenant    @relation(fields: [userId, tenantId], references: [userId, tenantId], onDelete: Cascade)
  rating               Rating?

  @@index([userId, tenantId])
  @@index([barberId, date])
  @@index([tenantId, date])
  @@index([status])
}

model BarberDisponibility {
  id        String     @id @default(uuid())
  dayOfWeek Int
  startTime DateTime   @db.Time(6)
  endTime   DateTime   @db.Time(6)
  barberId  String
  tenantId  String
  barber    Barber     @relation(fields: [barberId], references: [id], onDelete: Cascade)
  tenant    Barbershop @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([barberId, dayOfWeek])
  @@index([barberId, dayOfWeek])
}

model ExceptionDate {
  id        String     @id @default(uuid())
  date      DateTime   @db.Date
  isClosed  Boolean    @default(true)
  startTime DateTime?  @db.Time(6)
  endTime   DateTime?  @db.Time(6)
  barberId  String
  tenantId  String
  barber    Barber     @relation(fields: [barberId], references: [id], onDelete: Cascade)
  tenant    Barbershop @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([barberId, date])
  @@index([barberId, date])
}

model Rating {
  id          String     @id @default(uuid())
  ratingValue Int        @default(0)
  comment     String?
  bookingId   String     @unique
  barberId    String
  userId      String
  tenantId    String
  createdAt   DateTime   @default(now())
  asked       Boolean    @default(false)
  barber      Barber     @relation(fields: [barberId], references: [id])
  booking     Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id])
  tenant      Barbershop @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([barberId, ratingValue])
}

model SocialMedia {
  id       String     @id @default(uuid())
  barberId String
  tenantId String
  platform String
  url      String
  barber   Barber     @relation(fields: [barberId], references: [id], onDelete: Cascade)
  tenant   Barbershop @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([barberId, tenantId])
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  INCOMPLETE
}

enum userRole {
  CLIENT
  BARBER
  ADMIN
  USER
}

enum BookingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}
